{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shimmerfield-site",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "not_found_handling": "none"
  }
}
